---
import ProjectCard from '../components/ProjectCard.astro';
import { pb } from '../lib/pocketbase';
import { Image } from 'astro:assets';
// import myPicture from '../assets/me.jpg'; // Uncomment this when you have your pic

const projects = await pb.collection('projects').getFullList({ sort: '-created' });
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>My Portfolio</title>
  </head>
  <body class="bg-white text-slate-900">
    
    <section class="max-w-6xl mx-auto px-6 py-16 md:py-24">
      <div class="flex flex-col md:flex-row items-center gap-12">
        
        <div class="w-48 h-48 md:w-64 md:h-64 shrink-0">
          <img 
            src="https://via.placeholder.com/400" 
            alt="Your Name" 
            class="w-full h-full object-cover rounded-2xl shadow-2xl rotate-3 hover:rotate-0 transition-transform duration-500"
          />
          </div>

        <div class="flex-1 text-center md:text-left">
          <h1 class="text-4xl md:text-6xl font-black tracking-tight mb-4">
            Hey, I'm <span class="text-blue-600">Your Name.</span>
          </h1>
          <p class="text-lg md:text-xl text-slate-600 leading-relaxed mb-6">
            I'm a developer building fast web experiences. I love working with 
            <strong>Astro</strong>, <strong>Tailwind</strong>, and <strong>PocketBase</strong>. 
            Currently focusing on building clean, functional user interfaces.
          </p>
          <div class="flex flex-wrap justify-center md:justify-start gap-3">
            <span class="px-3 py-1 bg-slate-100 text-slate-600 rounded-md text-sm font-medium">Full Stack</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-600 rounded-md text-sm font-medium">UI/UX Design</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-600 rounded-md text-sm font-medium">Open Source</span>
          </div>
        </div>

      </div>
    </section>


  </body>
</html>