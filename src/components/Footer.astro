---
import Icon from "./Icon.astro";
import type { iconPaths } from './IconPaths';

const currentYear = new Date().getFullYear();

const iconLinks: { label: string; href: string; icon: keyof typeof iconPaths }[] = [
  { label: 'Phone', href: 'tel:203-682-5864', icon: 'phone' },
  { label: 'Email', href: 'mailto:agrawal.aar@northeastern.edu', icon: 'envelope' },
  { label: 'GitHub', href: 'https://github.com/aarushiagrawal', icon: 'github-logo' },
  { label: 'Insta', href: 'https://www.instagram.com/yourhandle', icon: 'instagram-logo' },
  { label: 'YouTube', href: 'https://www.youtube.com/@me/', icon: 'youtube-logo' },
];
---

<footer>
  <div class="group">

    <p>© {currentYear} Aarushi Agrawal</p>
  </div>

  <div class="socials">
    {
      iconLinks.map(({ href, icon, label }) => (
        <a href={href} class="social-link">
          <span class="sr-only">{label}</span>
          <Icon icon={icon} size="1.5rem" />
        </a>
      ))
    }
  </div>
</footer>

<style>
  footer {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    margin-top: auto;
    padding: 3rem 2rem 3rem;
    text-align: center;
    color: var(--gray-400);
    font-size: var(--text-sm);
    border-top: 1px solid var(--gray-800);
  }

  footer a {
    color: var(--gray-400);
    text-decoration: 1px solid underline transparent;
    text-underline-offset: 0.25em;
    transition: text-decoration-color var(--theme-transition);
  }

  footer a:hover,
  footer a:focus {
    text-decoration-color: currentColor;
    color: var(--accent-regular);
  }

  .group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .socials {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .social-link {
    display: flex;
    padding: 0.5rem;
    border-radius: 50%;
    color: var(--gray-300);
    transition: 
      color var(--theme-transition), 
      background-color var(--theme-transition),
      transform 0.2s ease;
  }

  .social-link:hover {
    color: var(--accent-regular);
    background-color: var(--gray-999_40);
    transform: translateY(-2px);
  }

  @media (min-width: 50em) {
    footer {
      flex-direction: row;
      justify-content: space-between;
      padding: 2.5rem 5rem;
    }

    .group {
      flex-direction: row;
      gap: 2.5rem;
      text-align: left;
    }

    .socials {
      justify-content: flex-end;
      gap: 1rem;
    }
  }
</style>