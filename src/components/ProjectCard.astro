---
// src/components/ProjectCard.astro
const { project } = Astro.props;
const pbUrl = import.meta.env.PUBLIC_POCKETBASE_URL;

// Construct the PocketBase image URL
// Format: [URL]/api/files/[COLLECTION_ID]/[RECORD_ID]/[FILENAME]
const imageUrl = project.img 
  ? `${pbUrl}/api/files/${project.collectionId}/${project.id}/${project.img}`
  : 'https://via.placeholder.com/400x250?text=No+Image';
---

<div class="group bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
  <div class="relative aspect-video overflow-hidden">
    <img 
      src={imageUrl} 
      alt={project.name} 
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
    <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm text-slate-700 text-xs font-bold px-3 py-1 rounded-full shadow-sm border border-slate-100">
      {project.timeframe}
    </div>
  </div>

  <div class="p-5">
    <h3 class="text-xl font-bold text-slate-800 mb-2 group-hover:text-blue-600 transition-colors">
      {project.name}
    </h3>
    <p class="text-slate-600 text-sm leading-relaxed line-clamp-3 mb-4">
      {project.des}
    </p>
    
    <div class="flex items-center justify-between mt-auto">
      <span class="text-xs font-medium text-slate-400 uppercase tracking-wider">Project Details</span>
      <div class="h-8 w-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 group-hover:bg-blue-600 group-hover:text-white transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="out 14l-4 4m0 0l-4-4m4 4V4" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </div>
    </div>
  </div>
</div>